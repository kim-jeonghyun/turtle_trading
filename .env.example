# 터틀 트레이딩 시스템 환경 변수

# ===== 알림 설정 =====
# 알림 채널 참고: config/notifications.yaml.example
# 각 채널은 독립적으로 활성화/비활성화 가능 (미설정 시 해당 채널 비활성화)

# --- Telegram ---
# BotFather에서 발급받은 토큰
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# 메시지를 수신할 채널 또는 사용자의 chat ID (음수 가능)
TELEGRAM_CHAT_ID=your_chat_id

# --- Discord ---
# 서버 채널 설정 → 채널 편집 → Webhooks에서 생성
# 형식: https://discord.com/api/webhooks/{webhook.id}/{webhook.token}
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# --- Email (SMTP) ---
# Gmail 사용 시 앱 비밀번호 필요 (2단계 인증 활성화 후 발급)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
# 수신자 목록 (쉼표로 구분, 공백 없이)
EMAIL_TO=recipient1@email.com,recipient2@email.com

# ===== 한국투자증권 KIS API =====

# 실전투자: True, 모의투자: False
KIS_IS_REAL=False

KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_SUFFIX=01

# ===== 트레이딩 설정 =====

# 초기 자본금
INITIAL_CAPITAL=100000

# 리스크 비율 (0.01 = 1%, 0.02 = 2%)
RISK_PERCENT=0.01

# 시스템 (1 or 2)
TURTLE_SYSTEM=1

# 최대 Unit 수
MAX_UNITS=4

# ===== 시간대 =====
TZ=Asia/Seoul

# ===== Docker 설정 =====
# Linux에서 호스트 UID/GID가 1000이 아닌 경우 설정 (macOS에서는 불필요)
# DOCKER_UID=1000
# DOCKER_GID=1000
