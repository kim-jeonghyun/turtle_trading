# 터틀 트레이딩 시스템 Cron 설정
# 시간대: Asia/Seoul (KST)

# 환경 변수
TZ=Asia/Seoul
SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
PYTHONPATH=/app

# 한국 시장 시그널+포지션 체크 (장 마감 후 16:00)
0 16 * * 1-5 cd /app && python scripts/check_positions.py >> /app/logs/check_kr.log 2>&1

# 미국 시장 시그널+포지션 체크 (한국시간 07:00)
# NOTE: KR 심볼도 재처리됨 (should_check_signals 통과). 무해 — v3.3.0에서 --market 인자로 분리 예정
0 7 * * 2-6 cd /app && python scripts/check_positions.py >> /app/logs/check_us.log 2>&1

# 일일 리포트 (매일 08:00)
0 8 * * * cd /app && python scripts/daily_report.py >> /app/logs/daily_report.log 2>&1

# 캐시 정리 (매주 일요일 03:00)
0 3 * * 0 find /app/data/cache -type f -mtime +7 -delete >> /app/logs/cleanup.log 2>&1

# 데이터 백업 (매일 02:00)
0 2 * * * cd /app && bash scripts/backup_data.sh >> /app/logs/backup.log 2>&1

# 시스템 건강 점검 (매 4시간)
0 */4 * * * cd /app && python scripts/health_check.py >> /app/logs/health_check.log 2>&1

# === 장중 모니터링 (5분 간격) ===
# 내부 is_market_open() 게이트가 마켓 시간/공휴일/DST 보정
# cron은 최대 범위로 설정, 불필요 호출은 스크립트가 즉시 종료
# 로그는 Python TimedRotatingFileHandler가 관리 (>> 리디렉션 불필요)

# KR 장중: 09:00-15:25 KST, 월-금
*/5 9-14 * * 1-5 cd /app && python scripts/monitor_positions.py
0,5,10,15,20,25 15 * * 1-5 cd /app && python scripts/monitor_positions.py

# US 장중: DST 양방향 커버 22:00-06:25 KST
# - 표준시(EST): US 장 KST 23:30-06:00 → 22:00 시작으로 여유
# - 서머타임(EDT): US 장 KST 22:30-05:00 → 22:00 시작 정확
*/5 22-23 * * 1-5 cd /app && python scripts/monitor_positions.py
*/5 0-5 * * 2-6 cd /app && python scripts/monitor_positions.py
0,5,10,15,20,25 6 * * 2-6 cd /app && python scripts/monitor_positions.py

# 리스크 한도 점검 (KR장중 09-15시)
0 9-15 * * 1-5 cd /app && python scripts/check_risk_limits.py >> /app/logs/risk_check.log 2>&1

# 리스크 한도 점검 (US장중 KST 23-06시)
0 23 * * 1-5 cd /app && python scripts/check_risk_limits.py >> /app/logs/risk_check.log 2>&1
0 0-6 * * 2-6 cd /app && python scripts/check_risk_limits.py >> /app/logs/risk_check.log 2>&1

# 주간 리포트 (매주 토요일 09:00)
0 9 * * 6 cd /app && python scripts/weekly_report.py --send >> /app/logs/weekly_report.log 2>&1

# 로그 정리 (매주 일요일 04:00, 14일 이상 된 로그 삭제)
0 4 * * 0 find /app/logs -name "*.log" -mtime +14 -delete >> /app/logs/cleanup.log 2>&1

# 시그널/거래 파일 정리 (매월 1일 03:30, 90일 이상 된 parquet 삭제)
30 3 1 * * find /app/data/signals -name "*.parquet" -mtime +90 -delete && find /app/data/trades -name "*.parquet" -mtime +90 -delete >> /app/logs/cleanup.log 2>&1

# 빈 줄 필수
